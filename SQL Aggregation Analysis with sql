  ---13).•	compny don't know  Ranked cities by Total Spend vs. Average Order Value (AOV).


SELECT top 10
    location,

    SUM([ purchase_amount]) AS Total_Spend,

    COUNT([ purchase_amount]) AS Total_Orders,

    ROUND(
        SUM([ purchase_amount]) * 1.0 / COUNT(customer_id),
        2
    ) AS Average_Order_Value,

    RANK() OVER (
        ORDER BY SUM([ purchase_amount]) DESC
    ) AS Spend_Rank,

    RANK() OVER (
        ORDER BY 
        SUM([ purchase_amount]) * 1.0 / COUNT(customer_id) DESC
    ) AS AOV_Rank

FROM [dbo].[costumer_behaviour_analysis]
GROUP BY location

ORDER BY Spend_Rank;

---business pronlem:-Where to invest more
                   --Which regions need improvement
                   --Which cities generate maximum profit
    ---impact:-
             -- Reduces unnecessary spending
             --Improves ROI
             --Supports strategic planning
               

---?14).The business needed to identify high-performing product categories to optimize sales strategy, 
--inventory planning, and revenue growth, revealing Electronics as the dominant contributor to total spend.

SELECT 
    category,
    SUM([ purchase_amount]) AS total_spend,

    ROUND(
        (SUM([ purchase_amount]) * 100.0) /
        (SELECT SUM([ purchase_amount])
         FROM [costumer_behaviour_analysis] ),
    2) AS spend_percentage

FROM  [dbo].[costumer_behaviour_analysis]
GROUP BY category
ORDER BY total_spend DESC;

--business impact:-
---Identified Electronics as the top revenue-generating category.
---Helped improve inventory and marketing decisions.
---Increased focus on high-profit business segments.

